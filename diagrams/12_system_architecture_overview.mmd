flowchart LR
    subgraph Client[Client Layer]
        FE[Frontend App]
        STAFF[Staff App]
    end

    subgraph Edge[Edge Layer]
        CF[Cloudflare Tunnel]
        KONG[Kong Gateway]
    end

    subgraph Core[Core Layer]
        subgraph Orch[Orchestrators]
            AUTH[auth]
            EVENT[event]
            CREDIT[credit]
            PURCHASE[purchase]
            QR[qr]
            MARKET[marketplace]
            TRANSFER[transfer]
            VERIFY[verification]
        end

        subgraph Services[Services]
            USER[user]
            VENUE[venue]
            SEAT[seat]
            EVENT_SVC[event]
            INVENTORY[inventory]
            TICKET[ticket]
            TICKET_LOG[ticket-log]
            MARKET_SVC[marketplace]
            TRANSFER_SVC[transfer]
            CREDIT_TXN[credit-transaction]
            STRIPE[stripe-wrapper]
            OTP[otp-wrapper]
            NOTIF[notification]
        end
    end

    subgraph Data[Data Layer]
        PG[(PostgreSQL x10)]
        REDIS[(Redis)]
        RABBIT[(RabbitMQ)]
    end

    subgraph External[External]
        OUTSYS[OutSystems Credit API]
        SMU[SMU Notification API]
        STRIPE_EXT[Stripe]
    end

    FE --> CF
    STAFF --> CF
    CF --> KONG
    KONG --> AUTH
    KONG --> EVENT
    KONG --> CREDIT
    KONG --> PURCHASE
    KONG --> QR
    KONG --> MARKET
    KONG --> TRANSFER
    KONG --> VERIFY

    AUTH --> USER
    AUTH --> OUTSYS
    EVENT --> VENUE
    EVENT --> SEAT
    EVENT --> EVENT_SVC
    EVENT --> INVENTORY
    CREDIT --> STRIPE
    CREDIT --> CREDIT_TXN
    CREDIT --> OUTSYS
    PURCHASE --> INVENTORY
    PURCHASE --> TICKET
    PURCHASE --> CREDIT_TXN
    PURCHASE --> OUTSYS
    PURCHASE --> REDIS
    PURCHASE --> RABBIT
    QR --> TICKET
    QR --> EVENT_SVC
    QR --> VENUE
    MARKET --> MARKET_SVC
    MARKET --> TICKET
    MARKET --> EVENT_SVC
    MARKET --> USER
    TRANSFER --> TRANSFER_SVC
    TRANSFER --> MARKET_SVC
    TRANSFER --> TICKET
    TRANSFER --> CREDIT_TXN
    TRANSFER --> OTP
    TRANSFER --> OUTSYS
    TRANSFER --> RABBIT
    VERIFY --> TICKET
    VERIFY --> TICKET_LOG
    VERIFY --> EVENT_SVC
    VERIFY --> VENUE
    VERIFY --> INVENTORY
    VERIFY --> REDIS
    OTP --> SMU
    STRIPE --> STRIPE_EXT
    NOTIF --> REDIS
    NOTIF -. realtime push .-> FE
    NOTIF -. realtime push .-> STAFF
    USER --> PG
    VENUE --> PG
    SEAT --> PG
    EVENT_SVC --> PG
    INVENTORY --> PG
    TICKET --> PG
    TICKET_LOG --> PG
    MARKET_SVC --> PG
    TRANSFER_SVC --> PG
