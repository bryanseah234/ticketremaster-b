flowchart LR
    subgraph Client[Client Layer]
        FE[Frontend App]
        STAFF[Staff App]
    end

    subgraph Edge[Edge Layer]
        CF[Cloudflare Tunnel]
        KONG[Kong Gateway]
    end

    subgraph Core[Core Layer]
        subgraph Orch[Orchestrators]
            AUTH[auth]
            EVENT[event]
            CREDIT[credit]
            PURCHASE[purchase]
            QR[qr]
            MARKET[marketplace]
            TRANSFER[transfer]
            VERIFY[verification]
        end

        subgraph Services[Services]
            USER[user]
            VENUE[venue]
            SEAT[seat]
            EVENT_SVC[event]
            INVENTORY[inventory]
            TICKET[ticket]
            MARKET_SVC[marketplace]
            TRANSFER_SVC[transfer]
            CREDIT_TXN[credit-transaction]
            STRIPE[stripe-wrapper]
            OTP[otp-wrapper]
            NOTIF[notification]
        end
    end

    subgraph Data[Data Layer]
        PG[(PostgreSQL x10)]
        REDIS[(Redis)]
        RABBIT[(RabbitMQ)]
    end

    subgraph External[External]
        OUTSYS[OutSystems Credit API]
        STRIPE_EXT[Stripe]
    end

    FE --> CF
    STAFF --> CF
    CF --> KONG
    KONG --> AUTH
    KONG --> EVENT
    KONG --> CREDIT
    KONG --> PURCHASE
    KONG --> QR
    KONG --> MARKET
    KONG --> TRANSFER
    KONG --> VERIFY

    AUTH --> USER
    EVENT --> EVENT_SVC
    PURCHASE --> INVENTORY
    QR --> TICKET
    MARKET --> MARKET_SVC
    TRANSFER --> TRANSFER_SVC
    TRANSFER --> OTP
    VERIFY --> TICKET

    USER --> PG
    EVENT_SVC --> PG
    INVENTORY --> PG
    TICKET --> PG
    MARKET_SVC --> PG
    TRANSFER_SVC --> PG

    PURCHASE --> REDIS
    NOTIF --> REDIS
    PURCHASE --> RABBIT
    TRANSFER --> RABBIT

    CREDIT --> OUTSYS
    CREDIT --> STRIPE_EXT

    NOTIF -.-> FE
    NOTIF -.-> STAFF
