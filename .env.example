# ── General ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ── Observability ────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Security ────────────────────────────────────────────────────
# IMPORTANT: All secrets must be set to secure, unique values in production
# The application will fail to start if these are left as default values
JWT_SECRET=change_me  # Must be at least 32 characters, cryptographically random
QR_SECRET=change_me   # Must be at least 32 characters
SEAT_HOLD_DURATION_SECONDS=600
CLOCK_SKEW_SECONDS=300  # Allow up to 5 minutes clock skew for QR verification

# ── External APIs ───────────────────────────────────────────────
# IMPORTANT: These must be set to secure values in production
OUTSYSTEMS_API_KEY=change_me
CREDIT_SERVICE_URL=https://your-outsystems-credit-service.example.com
STRIPE_SECRET_KEY=sk_test_change_me  # Must be a valid Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_change_me  # Must be your Stripe webhook signing secret
SMU_API_URL=https://smuedu-dev.outsystemsenterprise.com/SMULab_Notification/rest/Notification
SMU_API_KEY=change_me

# ── RabbitMQ ────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MANAGEMENT_PORT=15672

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Kong API Gateway ────────────────────────────────────────────
# API keys for Kong authentication - must be rotated in production
# These are used by the frontend and partner applications to access the API
KONG_FRONTEND_API_KEY=tk_front_123456789  # Change in production
KONG_PARTNER_API_KEY=tk_partner_abcdefg   # Change in production

# ── Cloudflare ──────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=change_me

# ── gRPC ────────────────────────────────────────────────────────
SEAT_INVENTORY_GRPC_HOST=seat-inventory-service
SEAT_INVENTORY_GRPC_PORT=50051

# ── Service URLs (internal Docker network) ──────────────────────
USER_SERVICE_URL=http://user-service:5000
VENUE_SERVICE_URL=http://venue-service:5000
SEAT_SERVICE_URL=http://seat-service:5000
EVENT_SERVICE_URL=http://event-service:5000
SEAT_INVENTORY_SERVICE_URL=http://seat-inventory-service:5000
CREDIT_TRANSACTION_SERVICE_URL=http://credit-transaction-service:5000
TICKET_SERVICE_URL=http://ticket-service:5000
TICKET_LOG_SERVICE_URL=http://ticket-log-service:5000
MARKETPLACE_SERVICE_URL=http://marketplace-service:5000
TRANSFER_SERVICE_URL=http://transfer-service:5000
STRIPE_WRAPPER_URL=http://stripe-wrapper:5000
OTP_WRAPPER_URL=http://otp-wrapper:5000
AUTH_ORCHESTRATOR_URL=http://auth-orchestrator:5000
EVENT_ORCHESTRATOR_URL=http://event-orchestrator:5000
CREDIT_ORCHESTRATOR_URL=http://credit-orchestrator:5000
TICKET_PURCHASE_ORCHESTRATOR_URL=http://ticket-purchase-orchestrator:5000
QR_ORCHESTRATOR_URL=http://qr-orchestrator:5000
MARKETPLACE_ORCHESTRATOR_URL=http://marketplace-orchestrator:5000
TRANSFER_ORCHESTRATOR_URL=http://transfer-orchestrator:5000
TICKET_VERIFICATION_ORCHESTRATOR_URL=http://ticket-verification-orchestrator:5000

# ─── User Service DB ─────────────────────────────────────────────
USER_SERVICE_DB_HOST=user-service-db
USER_SERVICE_DB_PORT=5432
USER_SERVICE_DB_NAME=user_service
USER_SERVICE_DB_USER=ticketremaster
USER_SERVICE_DB_PASSWORD=change_me
USER_SERVICE_DATABASE_URL=postgresql://ticketremaster:change_me@user-service-db:5432/user_service

