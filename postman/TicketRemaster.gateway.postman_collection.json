    {
      "name": "02 Events",
      "item": [
        {
          "name": "List Events",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json')) {",
                  "  const body = pm.response.json();",
                  "  const events = (body.data && body.data.events) ? body.data.events : (Array.isArray(body.events) ? body.events : []);",
                  "  const seeded = events.find(e => e.eventId === 'evt_001') || events[0];",
                  "  if (seeded && seeded.eventId) { pm.environment.set('event_id', seeded.eventId); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/events"
          }
        },
        {
          "name": "Get Event Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/events/{{event_id}}"
          }
        },
        {
          "name": "Get Seat Map",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json') && pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const seats = (body.data && body.data.seats) ? body.data.seats : (Array.isArray(body.seats) ? body.seats : []);",
                  "  if (seats.length > 0) {",
                  "    const avail = seats.find(s => s.status === 'available') || seats[0];",
                  "    if (avail.inventoryId) { pm.environment.set('inventory_id', avail.inventoryId); }",
                  "    if (avail.seatId) { pm.environment.set('seat_id', avail.seatId); }",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "apikey", "value": "{{api_key}}" }
            ],
            "url": "{{gateway_url}}/events/{{event_id}}/seats"
          }
        }
      ]
    },
