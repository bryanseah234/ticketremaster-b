      "name": "00 Health",
      "item": [
        {
          "name": "Events (public - no auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json')) {",
                  "  const body = pm.response.json();",
                  "  const events = (body.data && body.data.events) ? body.data.events : (Array.isArray(body.events) ? body.events : []);",
                  "  if (events.length > 0 && events[0].eventId) {",
                  "    pm.environment.set('event_id', events[0].eventId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{gateway_url}}/events"
          }
        },
