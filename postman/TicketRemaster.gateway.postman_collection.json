    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const status = pm.response.code;",
                  "pm.test('Register returns 201 or 409 (already exists)', () => {",
                  "  pm.expect([201, 409]).to.include(status);",
                  "});",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json') && status === 201) {",
                  "  const body = pm.response.json();",
                  "  const uid = (body.data && body.data.userId) || body.userId;",
                  "  if (uid) { pm.environment.set('user_id', uid); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"TestPass123!\",\n  \"phoneNumber\": \"+6591234567\"\n}"
            },
            "url": "{{gateway_url}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json')) {",
                  "  const body = pm.response.json();",
                  "  // Response: { data: { token, user: { userId } } }",
                  "  const token = (body.data && body.data.token) || body.token || body.access_token;",
                  "  if (token) { pm.environment.set('auth_token', token); }",
                  "  const uid = (body.data && body.data.user && body.data.user.userId) || (body.data && body.data.userId) || body.userId;",
                  "  if (uid) { pm.environment.set('user_id', uid); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"TestPass123!\"\n}"
            },
            "url": "{{gateway_url}}/auth/login"
          }
        },
        {
          "name": "Get Current User (/auth/me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json')) {",
                  "  const body = pm.response.json();",
                  "  const uid = (body.data && body.data.userId) || body.userId;",
                  "  if (uid) { pm.environment.set('user_id', uid); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": "{{gateway_url}}/auth/me"
          }
        }
      ]
