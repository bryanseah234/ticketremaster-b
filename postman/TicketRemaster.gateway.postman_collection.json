    {
      "name": "04 Purchase",
      "item": [
        {
          "name": "Hold Seat",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Hold returns 200, 201, 409 or 404', () => pm.expect([200, 201, 409, 404]).to.include(pm.response.code));",
                  "const ct = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (ct.includes('application/json') && [200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  const holdId = (body.data && body.data.holdId) || body.holdId;",
                  "  if (holdId) { pm.environment.set('hold_id', holdId); }",
