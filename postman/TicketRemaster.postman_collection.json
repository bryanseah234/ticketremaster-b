    {
      "name": "01 User Service",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (contentType.includes('application/json')) {",
                  "  const body = pm.response.json();",
                  "  if (body.userId) { pm.environment.set('user_id', body.userId); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"prehashed-password\",\n  \"salt\": \"salt-001\",\n  \"phoneNumber\": \"+6591234567\",\n  \"role\": \"user\",\n  \"isFlagged\": false\n}"
            },
            "url": "{{user_service_url}}/users"
          }
        },
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (contentType.includes('application/json')) {",
                  "  const users = pm.response.json();",
                  "  if (Array.isArray(users)) {",
                  "    const targetEmail = pm.environment.get('user_email');",
                  "    const matched = users.find((u) => u.email === targetEmail) || users[0];",
                  "    if (matched && matched.userId) { pm.environment.set('user_id', matched.userId); }",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{user_service_url}}/users" }
        },
        { "name": "Get User By ID", "request": { "method": "GET", "url": "{{user_service_url}}/users/{{user_id}}" } },
        {
          "name": "Get User By Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "if (contentType.includes('application/json')) {",
                  "  const body = pm.response.json();",
                  "  if (body.userId) { pm.environment.set('user_id', body.userId); }",
                  "}"
                ]
              }
            }
          ],
          "request": { "method": "GET", "url": "{{user_service_url}}/users/by-email/{{user_email}}" }
        },
        {
          "name": "Patch User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"isFlagged\": true\n}" },
            "url": "{{user_service_url}}/users/{{user_id}}"
          }
        }
      ]
    },
