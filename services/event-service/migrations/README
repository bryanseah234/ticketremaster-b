# Migrations will be generated by Flask-Migrate when running in Docker
# Steps to generate migrations:
#
# 1. docker compose up -d event-service-db
# 2. docker compose run --rm event-service flask db init
# 3. docker compose run --rm event-service flask db migrate -m "create events table"
# 4. docker compose run --rm event-service flask db upgrade
#
# This creates the alembic.ini and migration scripts automatically
